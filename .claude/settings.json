{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "includeCoAuthoredBy": false,
    "permissions": {
        "allow": [
            "Bash(composer *)",
            "Bash(./vendor/bin/phel *)",
            "Bash(vendor/bin/phel *)",
            "Bash(./release.sh *)",
            "Bash(git *)",
            "Bash(gh *)",
            "Bash(ls *)",
            "Bash(wc *)",
            "Bash(timeout *)",
            "Bash(rm -rf .phel)",
            "Bash(rm -rf .phel/*)"
        ],
        "deny": [
            "Bash(rm -rf /:*)",
            "Bash(rm -rf ~*)",
            "Bash(rm -rf $HOME*)",
            "Bash(rm -rf ..*)",
            "Bash(rm -fr /:*)",
            "Bash(sudo:*)",
            "Bash(shutdown:*)",
            "Bash(reboot:*)",
            "Bash(mkfs:*)"
        ]
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/format-phel.sh",
                        "timeout": 30
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/protect-files.sh",
                        "timeout": 5
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "matcher": "compact",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/compact-context.sh"
                    }
                ]
            }
        ]
    },
    "statusLine": {
        "type": "command",
        "command": "/bin/bash .claude/statusline.sh"
    }
}
