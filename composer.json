{
  "name": "phel-lang/phel-sql",
  "description": "Data-driven SQL DSL for Phel Lang. HoneySQL-style. Pure data in, [sql params] out.",
  "keywords": [
    "phel",
    "lisp",
    "sql",
    "query-builder",
    "honeysql"
  ],
  "homepage": "https://phel-lang.org/",
  "license": "MIT",
  "type": "library",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": ">=8.4",
    "phel-lang/phel-lang": "^0.37"
  },
  "scripts": {
    "test": "vendor/bin/phel test",
    "format": "vendor/bin/phel format",
    "repl": [
      "Composer\\Config::disableProcessTimeout",
      "vendor/bin/phel repl"
    ]
  }
}
